<mujoco>
  <option gravity="0 0 -9.81"/>
  <include file="piper_scene_ik.xml"/>
  <include file="piper_dependencies.xml"/>

  <asset>
    <mesh name="chef_can_mesh" file="models/002_master_chef_can/textured.obj" scale="0.6 0.6 0.6"/> 
    <texture name="chef_can_texture" file="models/002_master_chef_can/texture_map.png" type="2d"/>
    <material name="chef_can_material" texture="chef_can_texture" specular="1" shininess="1"/>
  </asset>

  <worldbody>
    <include file="piper_right_ik.xml" />

    <body mocap="true" name="mocap">
      <site pos="0.1 0 0" size="0.1 0.002 0.002" type="box" name="mocap_site1" rgba="1 0.33 0.33 1"/>
      <site pos="0 0.1 0" size="0.002 0.1 0.002" type="box" name="mocap_site2" rgba="0.33 1 0.33 1"/>
      <site pos="0 0 0.1" size="0.002 0.002 0.1" type="box" name="mocap_site3" rgba="0.33 0.33 1 1"/>
    </body>

    <body name="chef_can" pos="-0.15 0.35 0.03" quat="0.707 0. 0.707 0"> <!-- 设置香蕉的位置 -->
      <joint type="free" name="chef_can_joint" pos="0 0 0" frictionloss="0.01"/>
      <inertial pos="0 0 0" mass="0.05" diaginertia="0.002 0.002 0.002" />
      <geom pos="0 0 0"  size="0.02 0.025 0.02" type="mesh" mesh="chef_can_mesh" name="chef_can_collision" material="chef_can_material" 
      density="1" friction="1 0.005 0.0001" mass="0.5" condim="4" solimp="2 1 0.01" solref="0.01 1" contype="1" conaffinity="2" />
      
    </body>

    <body name="pillar" pos="0.0 0.5 0.15">
      <geom pos="0 0 0" size="0.04 0.04 0.15" type="box" name="pillar" rgba="0.8 1 0.4 1"
            solref="0.001 1" solimp="0.999 0.999 0.001" contype="1" conaffinity="2"/>
    </body>
  </worldbody>

  <actuator>
    <position name="joint1" ctrllimited="true" ctrlrange="-2.618 2.618" joint="joint1" kp="1500" user="1" forcelimited="false" forcerange="-250 250"/>
    <position name="joint2" ctrllimited="true" ctrlrange="0 3.14158" joint="joint2" kp="1600" user="1" forcelimited="false" forcerange="-250 250"/>
    <position name="joint3" ctrllimited="true" ctrlrange="-2.697 0" joint="joint3" kp="1600" user="1" forcelimited="false" forcerange="-250 250"/>
    <position name="joint4" ctrllimited="true" ctrlrange="-1.832 1.832" joint="joint4" kp="800" user="1" forcelimited="false" forcerange="-250 250"/>
    <position name="joint5" ctrllimited="true" ctrlrange="-1.22 1.22" joint="joint5" kp="400" user="1" forcelimited="false" forcerange="-250 250"/>
    <position name="joint6" ctrllimited="true" ctrlrange="-3.14158 3.14158" joint="joint6" kp="400" user="1" forcelimited="false" forcerange="-250 250"/>
    <position name="joint7" ctrllimited="true" ctrlrange="0.0105 0.035" joint="joint7" kp="500" user="1"/>
    <position name="joint8" ctrllimited="true" ctrlrange="-0.035 -0.0105" joint="joint8" kp="500" user="1"/>
  </actuator>
</mujoco>
